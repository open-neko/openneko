# transformers.js model cache — populated lazily on first embedText() call
# or via `pnpm --filter @neko/llm models:warm`. Files are large (>20MB
# quantized, >80MB FP32) and reproducible, so we don't track them.
packages/llm/.cache/
apps/web/.cache/

docs/
.turbo/
dist/
build/
out/
*.log
.DS_Store

.env
.env.local
.env.*.local

# GraphJin's working dir — everything except templates + committed
# operating-loop config is runtime
db/graphjin/*
!db/graphjin/dev.example.yml
!db/graphjin/neko.yml

# local onboarding scratch
adventureworks-onboarding.md

# editor
.vscode/
.idea/
*.swp

# local agent / Claude config
.agents/
.claude/

# design preview screenshots
design-preview/

# CLI runtime dir — embedded compose + scratch artifacts written when
# `openneko start` runs from the source checkout
.openneko/

# Per-host plugin manifest — written by `openneko plugin install`. Tracks
# the operator's installed plugins; not part of the source tree.
openneko.plugins.json
apps/*/openneko.plugins.json

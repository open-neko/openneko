{
  "name": "@open-neko/cli",
  "version": "1.5.0",
  "description": "Operator CLI for OpenNeko. Installs sandboxed plugins from the curated registry. Vendored into the open-neko/neko monorepo (was github.com/open-neko/cli).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-neko/neko.git",
    "directory": "apps/openneko-cli"
  },
  "type": "module",
  "bin": {
    "openneko": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@open-neko/plugin-install": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}

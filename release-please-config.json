{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "draft": false,
  "prerelease": false,
  "separate-pull-requests": false,
  "packages": {
    ".": { "package-name": "neko" },
    "apps/web": { "package-name": "@neko/web" },
    "apps/worker": { "package-name": "@neko/worker" },
    "packages/db": { "package-name": "@neko/db" },
    "packages/llm": { "package-name": "@neko/llm" }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "neko",
      "components": ["neko", "@neko/web", "@neko/worker", "@neko/db", "@neko/llm"]
    }
  ]
}

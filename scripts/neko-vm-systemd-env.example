# /etc/systemd/system/neko-worker.service.d/openneko-plugins.conf
#
# Drop-in env so neko-worker reads /opt/neko/.plugins for installed
# plugin packages (instead of the pnpm-managed /opt/neko/node_modules).
# Coordinated with the openneko install CLI's OPENNEKO_PLUGIN_INSTALL_DIR
# fallback — both must point at the same dir for installs from `openneko
# install` to be visible to the worker's plugin-registry.
#
# Apply once:
#   sudo mkdir -p /etc/systemd/system/neko-worker.service.d
#   sudo cp scripts/neko-vm-systemd-env.example \
#     /etc/systemd/system/neko-worker.service.d/openneko-plugins.conf
#   sudo systemctl daemon-reload
#   sudo systemctl restart neko-worker

[Service]
Environment="OPENNEKO_PLUGIN_INSTALL_DIR=/opt/neko/.plugins"

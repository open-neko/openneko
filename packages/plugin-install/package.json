{
  "name": "@open-neko/plugin-install",
  "version": "1.12.1",
  "private": true,
  "license": "Apache-2.0",
  "description": "Shared library for OpenNeko plugin install + secrets-store. Consumed by both the worker (reads the secrets store, will gain a server-side install path) and the openneko CLI (the operator-facing surface).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./secrets": "./src/secrets-store.ts",
    "./marketplace": "./src/marketplace-client.ts",
    "./manifest": "./src/manifest.ts",
    "./install": "./src/run-install.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
